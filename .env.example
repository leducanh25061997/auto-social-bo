# Base URL của API backend (auto-social-api).
# - Dev: để '/api/v1' và dùng proxy của Vite (xem vite.config.ts) -> tránh CORS.
# - Prod: đặt URL tuyệt đối, ví dụ https://api.example.com/api/v1
VITE_API_BASE_URL=/api/v1

# Đích proxy cho Vite dev server: forward các request '/api/*' sang backend.
# Chỉ dùng khi chạy dev; phải khớp PORT của auto-social-api (mặc định 3000).
VITE_API_PROXY_TARGET=http://localhost:3000

# App ID của Meta App để đăng nhập Facebook (developers.facebook.com).
# Để TRỐNG nếu chưa dùng — nút "Kết nối Facebook" sẽ báo chưa cấu hình.
# LƯU Ý: thêm "<origin>/oauth/facebook/callback" vào Valid OAuth Redirect URIs
# trong Meta App > Facebook Login > Settings.
VITE_FACEBOOK_APP_ID=

# Instagram App ID (Meta App > Instagram > API setup with Instagram login).
# Để TRỐNG nếu chưa dùng. Thêm "<origin>/oauth/instagram/callback" vào
# Valid OAuth Redirect URIs của phần Instagram login.
VITE_INSTAGRAM_APP_ID=
